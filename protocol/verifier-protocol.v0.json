{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ayush10212/receipts/protocol/verifier-protocol.v0.json",
  "title": "Receipts Verifier Protocol v0",
  "description": "JSON-RPC 2.0 over stdio contract between the Go core and any language verifier plugin. The Go core is opaque to the analyze payload — it passes artifacts through and assembles the returned claims into a Report. Adding a language = new plugin, zero core changes.",

  "$defs": {
    "jsonrpc_request": {
      "type": "object",
      "required": ["jsonrpc", "id", "method", "params"],
      "additionalProperties": false,
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id":      { "oneOf": [{ "type": "string" }, { "type": "integer" }] },
        "method":  { "type": "string" },
        "params":  {}
      }
    },
    "jsonrpc_response": {
      "type": "object",
      "required": ["jsonrpc", "id"],
      "additionalProperties": false,
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id":      { "oneOf": [{ "type": "string" }, { "type": "integer" }, { "type": "null" }] },
        "result":  {},
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code":    { "type": "integer" },
            "message": { "type": "string" },
            "data":    {}
          }
        }
      }
    },

    "initialize_params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "initialize_result": {
      "type": "object",
      "required": ["name", "version", "capabilities", "determinism"],
      "additionalProperties": false,
      "properties": {
        "name":         { "type": "string", "minLength": 1 },
        "version":      { "type": "string", "minLength": 1 },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "determinism":  { "enum": ["deterministic", "subjective"] }
      }
    },

    "artifact": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path":    { "type": "string", "minLength": 1 },
        "content": { "type": "string" }
      }
    },
    "analyze_context": {
      "type": "object",
      "required": ["workdir", "target_env", "language"],
      "additionalProperties": false,
      "properties": {
        "workdir":    { "type": "string", "minLength": 1 },
        "language":   { "type": "string", "minLength": 1 },
        "target_env": {
          "type": "object",
          "required": ["language", "version", "prefix"],
          "additionalProperties": false,
          "properties": {
            "language": { "type": "string" },
            "version":  { "type": "string" },
            "prefix":   { "type": "string" }
          }
        }
      }
    },
    "analyze_params": {
      "type": "object",
      "required": ["artifact", "context"],
      "additionalProperties": false,
      "properties": {
        "artifact": { "$ref": "#/$defs/artifact" },
        "context":  { "$ref": "#/$defs/analyze_context" }
      }
    },
    "claim": {
      "type": "object",
      "required": ["id", "type", "subtype", "text", "locus", "verdict", "confidence", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id":      { "type": "string", "minLength": 1 },
        "type":    { "type": "string", "minLength": 1 },
        "subtype": { "enum": ["import", "attribute", "kwarg"] },
        "text":    { "type": "string", "minLength": 1 },
        "locus": {
          "type": "object",
          "required": ["file", "line", "col"],
          "additionalProperties": false,
          "properties": {
            "file":     { "type": "string" },
            "line":     { "type": "integer", "minimum": 1 },
            "col":      { "type": "integer", "minimum": 0 },
            "end_line": { "type": "integer", "minimum": 1 },
            "end_col":  { "type": "integer", "minimum": 0 }
          }
        },
        "verdict":    { "enum": ["grounded", "contradicted", "unverifiable"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "detail"],
            "additionalProperties": false,
            "properties": {
              "kind":        { "type": "string" },
              "detail":      { "type": "string" },
              "determinism": { "enum": ["deterministic", "subjective"] }
            }
          }
        }
      }
    },
    "analyze_result": {
      "type": "object",
      "required": ["claims"],
      "additionalProperties": false,
      "properties": {
        "claims": { "type": "array", "items": { "$ref": "#/$defs/claim" } }
      }
    },

    "shutdown_params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "shutdown_result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    }
  },

  "examples": [
    {
      "_comment": "initialize request",
      "jsonrpc": "2.0", "id": 1, "method": "initialize", "params": {}
    },
    {
      "_comment": "initialize response",
      "jsonrpc": "2.0", "id": 1,
      "result": {
        "name": "python-symbols", "version": "0.1.0",
        "capabilities": ["python"], "determinism": "deterministic"
      }
    },
    {
      "_comment": "analyze request",
      "jsonrpc": "2.0", "id": 2, "method": "analyze",
      "params": {
        "artifact": { "path": "main.py", "content": "import pandas as pd\npd.DataFrame.append()" },
        "context": {
          "workdir": "/project",
          "language": "python",
          "target_env": { "language": "python", "version": "3.11.4", "prefix": "/home/user/.venv" }
        }
      }
    },
    {
      "_comment": "analyze response",
      "jsonrpc": "2.0", "id": 2,
      "result": {
        "claims": [
          {
            "id": "c-001", "type": "symbol", "subtype": "attribute",
            "text": "pandas.DataFrame.append",
            "locus": { "file": "main.py", "line": 2, "col": 0 },
            "verdict": "contradicted", "confidence": 1.0,
            "evidence": [{ "kind": "introspection", "detail": "removed in pandas 2.0", "determinism": "deterministic" }]
          }
        ]
      }
    },
    {
      "_comment": "shutdown request",
      "jsonrpc": "2.0", "id": 3, "method": "shutdown", "params": {}
    },
    {
      "_comment": "shutdown response",
      "jsonrpc": "2.0", "id": 3, "result": {}
    }
  ]
}
