{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ayush10212/receipts/protocol/report.v0.json",
  "title": "Receipts Report v0",
  "description": "Schema for a Receipts static-analysis report. Additive-only changes from v0.1.0.",
  "type": "object",
  "required": ["schema_version", "run", "claims", "policy", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "run": {
      "type": "object",
      "required": ["id", "timestamp", "tool_version", "inputs_hash", "target_env"],
      "additionalProperties": false,
      "properties": {
        "id":           { "type": "string", "minLength": 1 },
        "timestamp":    { "type": "string", "format": "date-time" },
        "tool_version": { "type": "string", "minLength": 1 },
        "inputs_hash":  { "type": "string", "minLength": 1 },
        "target_env": {
          "type": "object",
          "required": ["language", "version", "prefix"],
          "additionalProperties": false,
          "properties": {
            "language": { "type": "string", "minLength": 1 },
            "version":  { "type": "string", "minLength": 1 },
            "prefix":   { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "subtype", "text", "locus", "verdict", "confidence", "evidence", "verifier"],
        "additionalProperties": false,
        "properties": {
          "id":      { "type": "string", "minLength": 1 },
          "type":    { "type": "string", "minLength": 1 },
          "subtype": { "enum": ["import", "attribute", "kwarg"] },
          "text":    { "type": "string", "minLength": 1 },
          "locus": {
            "type": "object",
            "required": ["file", "line", "col"],
            "additionalProperties": false,
            "properties": {
              "file":     { "type": "string", "minLength": 1 },
              "line":     { "type": "integer", "minimum": 1 },
              "col":      { "type": "integer", "minimum": 0 },
              "end_line": { "type": "integer", "minimum": 1 },
              "end_col":  { "type": "integer", "minimum": 0 }
            }
          },
          "verdict":    { "enum": ["grounded", "contradicted", "unverifiable"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "detail"],
              "additionalProperties": false,
              "properties": {
                "kind":         { "type": "string", "minLength": 1 },
                "detail":       { "type": "string" },
                "determinism":  { "enum": ["deterministic", "subjective"] }
              }
            }
          },
          "verifier": {
            "type": "object",
            "required": ["name", "version", "determinism"],
            "additionalProperties": false,
            "properties": {
              "name":        { "type": "string", "minLength": 1 },
              "version":     { "type": "string", "minLength": 1 },
              "determinism": { "enum": ["deterministic", "subjective"] }
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": ["backend", "decision", "rules_applied"],
      "additionalProperties": false,
      "properties": {
        "backend":       { "type": "string", "minLength": 1 },
        "decision":      { "enum": ["pass", "warn", "fail"] },
        "rules_applied": { "type": "array", "items": { "type": "string" } }
      }
    },
    "summary": {
      "type": "object",
      "required": ["grounded", "contradicted", "unverifiable"],
      "additionalProperties": false,
      "properties": {
        "grounded":      { "type": "integer", "minimum": 0 },
        "contradicted":  { "type": "integer", "minimum": 0 },
        "unverifiable":  { "type": "integer", "minimum": 0 }
      }
    }
  }
}
